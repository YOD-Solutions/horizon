{%- liquid
  assign product_resource = closest.product
  assign block_settings = block.settings
  assign variant = product_resource.selected_or_first_available_variant

  assign default_country = block_settings.default_country_code
  if default_country == blank
    assign first_market_country = localization.available_countries | first
    if first_market_country != blank
      assign default_country = first_market_country.iso_code
    endif
  endif
  if default_country == blank
    assign default_country = localization.country.iso_code
  endif

  assign sr_fg = block_settings.text_color | default: '#1a1a1a'
-%}

{% unless product_resource == blank %}
  <div
    class="shipping-rates"
    style="
      padding-block-start: {{ block_settings['padding-block-start'] }}px;
      padding-block-end: {{ block_settings['padding-block-end'] }}px;
      padding-inline-start: {{ block_settings['padding-inline-start'] }}px;
      padding-inline-end: {{ block_settings['padding-inline-end'] }}px;
      --sr-fg:            {{ sr_fg }};
      --sr-fg-subdued:    {{ sr_fg | color_modify: 'alpha', 0.55 }};
      --sr-fg-muted:      {{ sr_fg | color_modify: 'alpha', 0.20 }};
      --sr-fg-faint:      {{ sr_fg | color_modify: 'alpha', 0.08 }};
      --sr-fg-xfaint:     {{ sr_fg | color_modify: 'alpha', 0.02 }};
      --sr-fg-icon:       {{ sr_fg | color_modify: 'alpha', 0.40 }};
      --sr-fg-icon-dim:   {{ sr_fg | color_modify: 'alpha', 0.25 }};
      --sr-fg-icon-hover: {{ sr_fg | color_modify: 'alpha', 0.60 }};
      --sr-bg:            {{ block_settings.background_color | default: '#ffffff' }};
      --sr-radius:        {{ block_settings.border_radius }}px;
      --sr-border-width:  {{ block_settings.border_width }}px;
      --sr-border-color:  {{ block_settings.border_color }};
      --sr-accent:        {{ block_settings.button_background }};
      --sr-accent-fg:     {{ block_settings.button_text_color }};
    "
    {{ block.shopify_attributes }}
    {% unless variant.requires_shipping and variant.available %}
      hidden
    {% endunless %}
  >
    {% if block_settings.heading != blank %}
      <p class="shipping-rates__heading{% if block_settings.heading_bold %} shipping-rates__heading--bold{% endif %}">
        {{ block_settings.heading | escape }}
      </p>
    {% endif %}

    <form class="shipping-rates__form" id="jsrates-form-{{ block.id }}" novalidate>
      <details class="shipping-rates__advanced" id="jsrates-advanced-{{ block.id }}">
        <summary class="shipping-rates__advanced-summary">
          <svg
            class="shipping-rates__map-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="shipping-rates__address-text">
            {%- if block_settings.address_prefix != blank -%}
              <span class="shipping-rates__address-prefix">{{ block_settings.address_prefix | escape }} </span>
            {%- endif -%}
            <span class="shipping-rates__address-summary" id="jsrates-address-display-{{ block.id }}"></span
          ></span>
          <svg
            class="shipping-rates__edit-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
          </svg>
        </summary>
        <div class="shipping-rates__advanced-fields">
          {% if block_settings.show_country %}
            <div class="shipping-rates__field">
              <label class="shipping-rates__field-label" for="jsrates-country-{{ block.id }}">Country</label>
              <select class="shipping-rates__select" id="jsrates-country-{{ block.id }}">
                {% for country in localization.available_countries %}
                  <option
                    value="{{ country.iso_code }}"
                    {% if country.iso_code == default_country %}
                      selected
                    {% endif %}
                  >
                    {{ country.name }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}

          {% if block_settings.show_province %}
            <div class="shipping-rates__field" id="jsrates-province-group-{{ block.id }}" hidden>
              <label class="shipping-rates__field-label" for="jsrates-province-{{ block.id }}">State / Province</label>
              <select class="shipping-rates__select" id="jsrates-province-{{ block.id }}">
                <option value="">Select...</option>
              </select>
            </div>
          {% endif %}

          {% if block_settings.show_city %}
            <div class="shipping-rates__field">
              <label class="shipping-rates__field-label" for="jsrates-city-{{ block.id }}">City</label>
              <input
                class="shipping-rates__input"
                type="text"
                id="jsrates-city-{{ block.id }}"
                placeholder="City"
                autocomplete="address-level2"
              >
            </div>
          {% endif %}

          {% if block_settings.show_zip %}
            <div class="shipping-rates__field">
              <label class="shipping-rates__field-label" for="jsrates-zip-{{ block.id }}">
                {{ block_settings.label | default: 'Postcode / ZIP' | escape }}
              </label>
              <input
                class="shipping-rates__input"
                type="text"
                id="jsrates-zip-{{ block.id }}"
                name="postal_code"
                placeholder="{{ block_settings.placeholder | default: 'Enter postcode' | escape }}"
                autocomplete="postal-code"
                inputmode="text"
                maxlength="20"
              >
            </div>
          {% endif %}

          <button class="shipping-rates__button shipping-rates__button--full" type="submit">
            {{ block_settings.button_label | default: 'Update address' | escape }}
          </button>
        </div>
      </details>

      <p class="shipping-rates__error" id="jsrates-error-{{ block.id }}" role="alert" hidden></p>
    </form>

    <div class="shipping-rates__results" id="jsrates-results-{{ block.id }}" hidden>
      <ul class="shipping-rates__list" id="jsrates-list-{{ block.id }}"></ul>
    </div>
  </div>

  <script>
    (function () {
      var blockId = {{ block.id | json }};
      var form         = document.getElementById('jsrates-form-'           + blockId);
      var input        = document.getElementById('jsrates-zip-'            + blockId);
      var errorEl      = document.getElementById('jsrates-error-'          + blockId);
      var resultsEl    = document.getElementById('jsrates-results-'        + blockId);
      var listEl       = document.getElementById('jsrates-list-'           + blockId);
      var addressDisplayEl = document.getElementById('jsrates-address-display-' + blockId);
      var advancedEl       = document.getElementById('jsrates-advanced-'        + blockId);
      var countryEl        = document.getElementById('jsrates-country-'         + blockId);
      var provinceGrpEl    = document.getElementById('jsrates-province-group-'  + blockId);
      var provinceEl       = document.getElementById('jsrates-province-'        + blockId);
      var cityEl           = document.getElementById('jsrates-city-'            + blockId);

      var STORAGE_KEY    = 'jsrates_destination';
      var currencySymbol = {{ localization.country.currency.symbol | json }};
      var initialAvailable = {{ variant.available | json }};

      // Country codes available in Shopify Markets (for validating detected/saved country).
      var availableCountryCodes = [
        {% for country in localization.available_countries %}"{{ country.iso_code }}"{% unless forloop.last %},{% endunless %}{% endfor %}
      ];

      // Province lookup keyed by ISO code: { "AU": [{name, code}, ...], ... }
      // Built from /services/countries.js after page load.
      var countriesData = {};

      var productTitle = {{ product_resource.title | json }};
      var currentVariantId = {{ variant.id }};
      var variantsById = {
        {% for v in product_resource.variants %}
          {{ v.id | json }}: {
            "id":                  {{ v.id | json }},
            "title":               {{ v.title | json }},
            "price":               {{ v.price | json }},
            "grams":               {{ v.weight | json }},
            "sku":                 {{ v.sku | json }},
            "requires_shipping":   {{ v.requires_shipping | json }},
            "taxable":             {{ v.taxable | json }},
            "available":           {{ v.available | json }},
            "fulfillment_service": {{ v.fulfillment_service | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      // Customer's Shopify default address (null when logged out or no address saved).
      var customerAddress = {% if customer and customer.default_address and customer.default_address.zip != blank %}
        {
          country:    {{ customer.default_address.country_code | json }},
          province:   {{ customer.default_address.province_code | json }},
          city:       {{ customer.default_address.city | json }},
          postalCode: {{ customer.default_address.zip | json }}
        }
      {% else %}null{% endif %};

      var rateData = {
        "rate": {
          "origin": {
            "country": {{ shop.address.country.iso_code | json }},
            "city": {{ shop.address.city | json }},
            "postal_code": {{ shop.address.zip | json }},
            "province": {{ shop.address.province | json }},
            "name": {{ shop.name | json }},
            "address1": {{ shop.address.address1 | json }},
            "address2": {{ shop.address.address2 | json }},
            "company_name": {{ shop.name | json }}
          },
          "destination": {
            "country": {{ default_country | json }},
            "city": {{ block_settings.default_city | default: '' | json }},
            "postal_code": {{ block_settings.default_postal_code | default: '' | json }},
            "province": {{ block_settings.default_province_code | default: '' | json }},
            "name": null,
            "address1": null,
            "address2": null
          },
          "items": [
            {
              "name": {{ product_resource.title | append: ' - ' | append: variant.title | json }},
              "sku": {{ variant.sku | json }},
              "grams": {{ variant.weight | default: 0 }},
              "quantity": 1,
              "price": {{ variant.price | default: 0 }},
              "vendor": {{ product_resource.vendor | json }},
              "requires_shipping": {{ variant.requires_shipping }},
              "taxable": {{ variant.taxable }},
              "fulfillment_service": {{ variant.fulfillment_service | json }},
              "properties": {},
              "product_id": {{ product_resource.id }},
              "variant_id": {{ variant.id }}
            }
          ],
          "currency": {{ localization.country.currency.iso_code | json }},
          "locale": {{ localization.language.iso_code | json }},
          "order_totals": {
            "subtotal_price": {{ variant.price | default: 0 | json }},
            "total_price": {{ variant.price | default: 0 | json }},
            "discount_amount": "0"
          },
          "customer": {% if customer %}{ "id": {{ customer.id }}, "tags": {{ customer.tags | json }} }{% else %}null{% endif %}
        }
      };

      // --- localStorage helpers ---
      function saveDestination(dest) {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(dest)); } catch (e) {}
      }
      function loadDestination() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch (e) { return null; }
      }

      // --- UI helpers ---
      function formatMoney(cents) {
        return (cents / 100).toFixed(2);
      }

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.hidden = false;
        resultsEl.hidden = true;
      }

      function clearError() {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      function updateAddressSummary() {
        if (!addressDisplayEl) return;
        var d = rateData.rate.destination;
        var parts = [];
        if (d.city)        parts.push(d.city);
        if (d.province)    parts.push(d.province);
        if (d.country)     parts.push(d.country);
        if (d.postal_code) parts.push(d.postal_code);
        addressDisplayEl.textContent = parts.join(', ');
      }

      function renderRates(rates) {
        listEl.innerHTML = '';
        if (!rates || rates.length === 0) {
          listEl.innerHTML = '<li class="shipping-rates__item shipping-rates__item--empty">No shipping rates available for this location.</li>';
        } else {
          rates.forEach(function (rate) {
            var li = document.createElement('li');
            li.className = 'shipping-rates__item';
            var isFree = rate.total_price === 0;
            var price = isFree ? 'Free' : currencySymbol + formatMoney(rate.total_price);
            var priceClass = 'shipping-rates__rate-price' + (isFree ? ' shipping-rates__rate-price--free' : '');
            li.innerHTML =
              '<span class="shipping-rates__rate-name">' + rate.service_name + '</span>' +
              '<span class="' + priceClass + '">' + price + '</span>';
            listEl.appendChild(li);
          });
        }
        resultsEl.hidden = false;
      }

      // --- Country / Province helpers ---
      function isCountryAvailable(isoCode) {
        return availableCountryCodes.indexOf(isoCode) !== -1;
      }

      function populateProvinces(countryCode, selectValue) {
        if (!provinceEl || !provinceGrpEl) return;
        var provinces = (countriesData[countryCode] && countriesData[countryCode].provinces) || [];

        if (provinces.length === 0) {
          provinceEl.innerHTML = '<option value="">Select\u2026</option>';
          provinceEl.value = '';
          provinceGrpEl.hidden = true;
          rateData.rate.destination.province = null;
          return;
        }

        provinceGrpEl.hidden = false;
        provinceEl.innerHTML = '<option value="">Select\u2026</option>';
        provinces.forEach(function (p) {
          var opt = document.createElement('option');
          opt.value = p.code;
          opt.textContent = p.name;
          provinceEl.appendChild(opt);
        });

        // Restore a previously selected province if still valid
        var target = selectValue || rateData.rate.destination.province;
        if (target && provinceEl.querySelector('option[value="' + target + '"]')) {
          provinceEl.value = target;
          rateData.rate.destination.province = target;
        } else {
          rateData.rate.destination.province = null;
        }
      }

      // --- Set full address from a destination object ---
      // Priority: only apply a field if it has a non-empty value.
      // If detected country is not in available countries, keep current.
      function setAddress(dest) {
        // Country
        if (dest.country) {
          if (!countryEl || isCountryAvailable(dest.country)) {
            rateData.rate.destination.country = dest.country;
            if (countryEl) countryEl.value = dest.country;
          }
        }

        // Province — repopulate for current country then restore value
        populateProvinces(rateData.rate.destination.country, dest.province || null);

        // City
        if (dest.city !== undefined && dest.city !== null) {
          rateData.rate.destination.city = dest.city;
          if (cityEl) cityEl.value = dest.city;
        }

        // Postal code — always update to reflect the resolved address
        if (dest.postalCode) {
          rateData.rate.destination.postal_code = dest.postalCode;
          input.value = dest.postalCode;
        }

        updateAddressSummary();
      }

      // --- Cart cache (only used when include_cart_items is enabled) ---
      // Cached until a cart-mutating request completes, then invalidated.
      var includeCartItems   = {{ block_settings.include_cart_items | json }};
      var requireProvince = {{ block_settings.require_province | json }};
      var requireCity     = {{ block_settings.require_city | json }};

      function isAddressReady() {
        var country = countriesData[rateData.rate.destination.country];
        var zipRequired = country ? country.zip_required : true;
        if (zipRequired    && !rateData.rate.destination.postal_code) return false;
        if (requireProvince && !rateData.rate.destination.province)   return false;
        if (requireCity     && !rateData.rate.destination.city)       return false;
        return true;
      }

      var cartCache = { data: null, promise: null };

      // Invalidate cache whenever any cart mutation endpoint responds.
      (function () {
        var _fetch = window.fetch;
        window.fetch = function (input) {
          var url = typeof input === 'string' ? input : (input && input.url) || '';
          var p = _fetch.apply(this, arguments);
          if (/\/cart\/(add|change|update|clear)/.test(url)) {
            p.then(function () {
              cartCache.data = null;
              cartCache.promise = null;
              if (includeCartItems && isAddressReady()) {
                fetchRates(rateData.rate.destination.postal_code, false).catch(function () {});
              }
            }).catch(function () {});
          }
          return p;
        };
      }());

      function getCartItems() {
        if (cartCache.data)    return Promise.resolve(cartCache.data);
        if (cartCache.promise) return cartCache.promise;
        cartCache.promise = fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            cartCache.data    = cart.items || [];
            cartCache.promise = null;
            return cartCache.data;
          })
          .catch(function () {
            cartCache.promise = null;
            return [];
          });
        return cartCache.promise;
      }

      // --- Items payload builder ---
      function buildItemsPayload() {
        var pageItem = rateData.rate.items[0];
        if (!includeCartItems) return Promise.resolve([pageItem]);
        return getCartItems()
          .then(function (cartItems) {
            var items = cartItems.map(function (ci) {
              return {
                name:                ci.title,
                sku:                 ci.sku || '',
                grams:               ci.grams,
                quantity:            ci.quantity,
                price:               ci.price,
                vendor:              ci.vendor || '',
                requires_shipping:   ci.requires_shipping,
                taxable:             ci.taxable,
                fulfillment_service: ci.fulfillment_service || 'manual',
                properties:          ci.properties || {},
                product_id:          ci.product_id,
                variant_id:          ci.variant_id
              };
            });
            // Merge page item: add quantity if same variant already in cart, otherwise append.
            var found = false;
            for (var i = 0; i < items.length; i++) {
              if (items[i].variant_id === pageItem.variant_id) {
                items[i].quantity += pageItem.quantity;
                found = true;
                break;
              }
            }
            if (!found) items.push(pageItem);
            return items;
          })
          .catch(function () { return [pageItem]; });
      }

      // --- Core fetch ---
      function fetchRates(zip, detectLocation) {
        return buildItemsPayload().then(function (items) {
        var payload = JSON.parse(JSON.stringify(rateData));
        if (zip) payload.rate.destination.postal_code = zip;
        if (detectLocation) payload.rate._detectLocation = true;
        payload.rate.items = items;
        payload.rate.order_totals.subtotal_price = items.reduce(function (s, i) { return s + i.price * i.quantity; }, 0);
        payload.rate.order_totals.total_price    = payload.rate.order_totals.subtotal_price;

        return fetch({{ block_settings.api_endpoint | json }}, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-jsrates-shop-domain': {{ block_settings.shop_domain | json }},
            'x-jsrates-api-key': {{ block_settings.api_key | json }}
          },
          body: JSON.stringify(payload)
        })
          .then(function (res) {
            if (!res.ok) throw new Error('Request failed (' + res.status + ')');
            return res.json();
          })
          .then(function (data) {
            var loc = data._detectedLocation;
            if (loc) {
              setAddress({
                country:    loc.country    || null,
                province:   loc.regionCode || null,
                city:       loc.city       || null,
                postalCode: loc.postalCode || null
              });
              // Persist the detected destination
              saveDestination({
                country:    rateData.rate.destination.country,
                regionCode: rateData.rate.destination.province,
                city:       rateData.rate.destination.city,
                postalCode: rateData.rate.destination.postal_code
              });
              // Re-fetch with the now-known precise location
              if (rateData.rate.destination.postal_code) {
                return fetchRates(rateData.rate.destination.postal_code, false);
              }
            }
            renderRates(data.rates);
          });
        }); // end buildItemsPayload
      }

      // --- Address field event listeners ---
      if (countryEl) {
        countryEl.addEventListener('change', function () {
          rateData.rate.destination.country = this.value;
          rateData.rate.destination.province = null;
          populateProvinces(this.value, null);
        });
      }

      if (provinceEl) {
        provinceEl.addEventListener('change', function () {
          rateData.rate.destination.province = this.value || null;
        });
      }

      if (cityEl) {
        cityEl.addEventListener('change', function () {
          rateData.rate.destination.city = this.value.trim() || null;
        });
      }

      // --- Variant sync ---
      var container = form.closest('.shipping-rates');
      // --- Variant sync (theme-agnostic) ---
      // Deduplicates changes from both signal sources below.
      function handleVariantChange(variantId) {
        var id = parseInt(variantId, 10);
        if (!id || id === currentVariantId) return;
        var v = variantsById[id];
        if (!v) return;
        currentVariantId = id;
        container.hidden = !v.requires_shipping || !v.available;
        rateData.rate.items[0].name = productTitle + (v.title && v.title !== 'Default Title' ? ' - ' + v.title : '');
        rateData.rate.items[0].grams = v.grams || 0;
        rateData.rate.items[0].price = v.price || 0;
        rateData.rate.items[0].sku = v.sku || '';
        rateData.rate.items[0].requires_shipping = v.requires_shipping;
        rateData.rate.items[0].taxable = v.taxable;
        rateData.rate.items[0].variant_id = v.id;
        rateData.rate.order_totals.subtotal_price = v.price || 0;
        rateData.rate.order_totals.total_price = v.price || 0;
        clearError();
        if (v.requires_shipping && v.available && isAddressReady()) {
          fetchRates(rateData.rate.destination.postal_code, false).catch(function () {});
        } else {
          resultsEl.hidden = true;
        }
      }

      // --- Variant change detection (theme-agnostic, event-driven) ---
      (function () {
        var productSection = container.closest('[data-section-id]') || container.closest('section') || document.body;

        // Signal 1: intercept input[name="id"] setter — catches programmatic updates
        // from any modern theme (Horizon, Dawn, Sense, etc.).
        try {
          var variantInput = productSection.querySelector('input[name="id"]')
                          || document.querySelector('form[action*="/cart/add"] input[name="id"]');
          if (variantInput) {
            var proto = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, 'value');
            Object.defineProperty(variantInput, 'value', {
              configurable: true,
              get: proto.get,
              set: function (val) {
                proto.set.call(this, val);
                if (val) handleVariantChange(val);
              }
            });
          }
        } catch (e) {}

        // Signal 2: change event — catches classic themes using <select name="id">.
        productSection.addEventListener('change', function (e) {
          if (e.target && e.target.name === 'id') handleVariantChange(e.target.value);
        });

        // --- Quantity sync ---
        function handleQuantityChange(qty) {
          qty = parseInt(qty, 10);
          if (!qty || qty < 1) return;
          if (qty === rateData.rate.items[0].quantity) return;
          rateData.rate.items[0].quantity = qty;
          rateData.rate.order_totals.subtotal_price = rateData.rate.items[0].price * qty;
          rateData.rate.order_totals.total_price    = rateData.rate.items[0].price * qty;
          if (rateData.rate.items[0].requires_shipping && isAddressReady()) {
            fetchRates(rateData.rate.destination.postal_code, false).catch(function () {});
          }
        }

        // Quantity signal A: change event — covers typed input and most stepper buttons.
        productSection.addEventListener('change', function (e) {
          if (e.target && e.target.name === 'quantity') handleQuantityChange(e.target.value);
        });

        // Quantity signal B: setter intercept — covers stepper buttons that update
        // the input programmatically without firing a change event.
        try {
          var qtyInput = productSection.querySelector('input[name="quantity"]')
                      || document.querySelector('form[action*="/cart/add"] input[name="quantity"]');
          if (qtyInput) {
            var qtyProto = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, 'value');
            Object.defineProperty(qtyInput, 'value', {
              configurable: true,
              get: qtyProto.get,
              set: function (val) {
                qtyProto.set.call(this, val);
                handleQuantityChange(val);
              }
            });
          }
        } catch (e) {}

        // Signal 3: history intercept — catches pushState/replaceState calls.
        // Covers Horizon, Dawn, and any theme that updates ?variant= in the URL.
        (function () {
          function fromUrl(url) {
            try {
              var id = new URLSearchParams(new URL(String(url), location.origin).search).get('variant');
              if (id) handleVariantChange(id);
            } catch (e) {}
          }
          ['pushState', 'replaceState'].forEach(function (method) {
            var original = history[method];
            history[method] = function (state, title, url) {
              original.apply(this, arguments);
              if (url) fromUrl(url);
            };
          });
          // Signal 4: popstate — catches back/forward browser navigation.
          window.addEventListener('popstate', function () { fromUrl(location.href); });
        }());
      }());

      // --- Manual submit ---
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var zip = input.value.trim();
        if (!zip) {
          showError('Please enter a postcode or ZIP code.');
          return;
        }
        clearError();

        rateData.rate.destination.postal_code = zip;
        updateAddressSummary();
        saveDestination({
          country:    rateData.rate.destination.country,
          regionCode: rateData.rate.destination.province,
          city:       rateData.rate.destination.city,
          postalCode: zip
        });

        var btn = form.querySelector('button[type="submit"]');
        btn.disabled = true;
        var originalLabel = btn.textContent;
        btn.textContent = '\u2026';

        fetchRates(zip, false)
          .then(function () {
            if (advancedEl) advancedEl.removeAttribute('open');
          })
          .catch(function () {
            showError('Unable to retrieve shipping rates. Please try again.');
          })
          .finally(function () {
            btn.disabled = false;
            btn.textContent = originalLabel;
          });
      });

      // --- Initialise and auto-load (after province data is ready) ---
      function init() {
        populateProvinces(rateData.rate.destination.country, rateData.rate.destination.province);
        if (cityEl && rateData.rate.destination.city) cityEl.value = rateData.rate.destination.city;
        if (!input.value && rateData.rate.destination.postal_code) input.value = rateData.rate.destination.postal_code;
        updateAddressSummary();

        if (!rateData.rate.items[0].requires_shipping || !initialAvailable) return;

        var savedDest = loadDestination();
        if (savedDest && savedDest.postalCode) {
          // 1. User's previously saved address wins
          setAddress({
            country:    savedDest.country    || null,
            province:   savedDest.regionCode || null,
            city:       savedDest.city       || null,
            postalCode: savedDest.postalCode
          });
          fetchRates(savedDest.postalCode, false).catch(function () {});
        } else if (customerAddress && customerAddress.postalCode) {
          // 2. Logged-in customer's default Shopify address
          setAddress(customerAddress);
          fetchRates(customerAddress.postalCode, false).catch(function () {});
        } else {
          // 3. Geo-detect location via JsRates
          fetchRates(null, true).catch(function () {});
        }
      }

      // Apply saved address to rateData synchronously so the summary
      // renders once with the correct address, before any network requests.
      var _earlyDest = loadDestination();
      if (_earlyDest) {
        if (_earlyDest.country)    rateData.rate.destination.country      = _earlyDest.country;
        if (_earlyDest.regionCode) rateData.rate.destination.province     = _earlyDest.regionCode;
        if (_earlyDest.city)       rateData.rate.destination.city         = _earlyDest.city;
        if (_earlyDest.postalCode) rateData.rate.destination.postal_code  = _earlyDest.postalCode;
      } else if (customerAddress) {
        if (customerAddress.country)    rateData.rate.destination.country     = customerAddress.country;
        if (customerAddress.province)   rateData.rate.destination.province    = customerAddress.province;
        if (customerAddress.city)       rateData.rate.destination.city        = customerAddress.city;
        if (customerAddress.postalCode) rateData.rate.destination.postal_code = customerAddress.postalCode;
      }
      updateAddressSummary();

      fetch('/services/countries.js')
        .then(function(r) { return r.text(); })
        .then(function(text) {
          // Response: var Countries = {"Australia": {code:"AU", provinces:[...], province_codes:{...}}, ...}
          // Keys are country names; code is the ISO code.
          var start = text.indexOf('{');
          var end   = text.lastIndexOf('}') + 1;
          var raw = JSON.parse(text.substring(start, end));
          Object.keys(raw).forEach(function(countryName) {
            var c = raw[countryName];
            var codes = c.province_codes || {};
            countriesData[c.code] = {
              zip_required: c.zip_required !== false,
              provinces: (c.provinces || []).map(function(name) {
                return { name: name, code: codes[name] || name };
              })
            };
          });
        })
        .catch(function() { /* province data unavailable; widget still functional */ })
        .then(function() { init(); });
    })();
  </script>
{% endunless %}

{% stylesheet %}
  /*
    All color tokens are computed from block settings and injected via
    inline style — no theme CSS variable dependencies.
    Typography uses em/inherit so it scales with whatever theme section
    the block is placed in.
  */
  .shipping-rates {
    /* spacing */
    --sr-gap-xs: 4px;
    --sr-gap-sm: 8px;
    --sr-pad-2xs: 4px;
    --sr-pad-xs: 8px;
    --sr-pad-sm: 12px;
    --sr-input-height: 40px;
    /* type scale — all em values are relative to the 0.9375em container base */
    --sr-font-size: 1em; /* ~15px: inputs, selects, rate rows  */
    --sr-font-size-sm: 0.8em; /* ~12px: labels, address, error      */
    --sr-font-size-md: 1.133em; /* ~17px: heading                     */
    --sr-line-height: 1.5;
    --sr-bold: 700;
    --sr-medium: 500;

    font-size: 0.9375em; /* compact base — slightly below theme body size */
    font-family: inherit;
    display: grid;
    gap: var(--sr-gap-sm);
    background-color: var(--sr-bg, transparent);
    border: var(--sr-border-width, 0px) solid var(--sr-border-color, transparent);
    border-radius: var(--sr-radius, 4px);
  }

  .shipping-rates[hidden] {
    display: none;
  }

  .shipping-rates__heading {
    margin: 0;
    font-size: var(--sr-font-size-md);
    font-weight: var(--sr-medium);
    line-height: var(--sr-line-height);
  }

  .shipping-rates__heading--bold {
    font-weight: var(--sr-bold);
  }

  .shipping-rates__address-summary {
    color: inherit;
  }

  .shipping-rates__input {
    width: 100%;
    box-sizing: border-box;
    height: var(--sr-input-height);
    padding-inline: var(--sr-pad-sm);
    border: 1px solid var(--sr-fg-muted);
    border-radius: var(--sr-radius);
    background-color: var(--sr-bg);
    color: var(--sr-fg);
    font-size: var(--sr-font-size);
    line-height: var(--sr-line-height);
    font-family: inherit;
    outline-offset: 2px;
  }

  .shipping-rates__input:focus-visible {
    outline: 2px solid var(--sr-fg);
  }

  .shipping-rates__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--sr-input-height);
    padding-inline: var(--sr-pad-sm);
    background-color: var(--sr-accent);
    color: var(--sr-accent-fg);
    border: none;
    border-radius: var(--sr-radius);
    font-size: var(--sr-font-size);
    font-family: inherit;
    font-weight: var(--sr-bold);
    cursor: pointer;
    white-space: nowrap;
  }

  .shipping-rates__button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .shipping-rates__button--full {
    width: 100%;
  }

  .shipping-rates__error {
    margin: var(--sr-pad-2xs) 0 0;
    font-size: var(--sr-font-size-sm);
    color: #c0392b;
  }

  /* --- Collapsible address form --- */
  .shipping-rates__advanced {
    border-top: 1px solid var(--sr-fg-faint);
    padding-top: var(--sr-pad-xs);
  }

  .shipping-rates__advanced-summary {
    display: inline-flex;
    align-items: center;
    gap: var(--sr-gap-xs);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .shipping-rates__advanced-summary::-webkit-details-marker {
    display: none;
  }

  .shipping-rates__address-text {
    font-size: var(--sr-font-size);
    color: var(--sr-fg);
  }

  .shipping-rates__advanced-summary:hover .shipping-rates__address-text {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .shipping-rates__map-icon {
    flex-shrink: 0;
    color: var(--sr-fg-icon);
  }

  .shipping-rates__edit-icon {
    flex-shrink: 0;
    color: var(--sr-fg-icon-dim);
    transition: color 0.15s;
  }

  .shipping-rates__advanced-summary:hover .shipping-rates__edit-icon {
    color: var(--sr-fg-icon-hover);
  }

  .shipping-rates__advanced-fields {
    display: grid;
    gap: var(--sr-gap-sm);
    padding-top: var(--sr-pad-sm);
  }

  .shipping-rates__field {
    display: grid;
    gap: var(--sr-pad-2xs);
  }

  .shipping-rates__field[hidden] {
    display: none;
  }

  .shipping-rates__field-label {
    font-size: var(--sr-font-size-sm);
    color: var(--sr-fg-subdued);
  }

  .shipping-rates__select {
    width: 100%;
    height: var(--sr-input-height);
    padding-inline: var(--sr-pad-sm);
    border: 1px solid var(--sr-fg-muted);
    border-radius: var(--sr-radius);
    background-color: var(--sr-bg);
    color: var(--sr-fg);
    font-size: var(--sr-font-size);
    font-family: inherit;
    appearance: auto;
    outline-offset: 2px;
    cursor: pointer;
  }

  .shipping-rates__select:focus-visible {
    outline: 2px solid var(--sr-fg);
  }

  /* --- Rates list --- */
  .shipping-rates__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    border: 1px solid var(--sr-fg-muted);
    border-radius: var(--sr-radius);
    overflow: hidden;
  }

  .shipping-rates__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sr-gap-sm);
    padding: var(--sr-pad-xs) var(--sr-pad-sm);
    font-size: var(--sr-font-size);
    background-color: var(--sr-fg-xfaint);
    border-top: 1px solid var(--sr-fg-faint);
  }

  .shipping-rates__item:first-child {
    border-top: none;
  }

  .shipping-rates__item--empty {
    color: var(--sr-fg-subdued);
    font-size: var(--sr-font-size-sm);
    justify-content: center;
  }

  .shipping-rates__rate-name {
    flex: 1 1 auto;
  }

  .shipping-rates__rate-price {
    font-weight: var(--sr-bold);
    white-space: nowrap;
  }

  .shipping-rates__rate-price--free {
    color: var(--sr-accent);
  }
{% endstylesheet %}

