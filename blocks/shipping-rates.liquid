      "type": "text",
      "id": "api_key",
      "label": "JsRates API key",
      "info": "API key from JsRates Settings → API. Enable domain whitelisting to restrict access."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check shipping rates"
    },
    {
      "type": "text",
      "id": "label",
