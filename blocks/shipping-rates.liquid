      "default": "Postcode / ZIP"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter postcode"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get rates"
    },
    {
      "type": "header",
