{% liquid
  assign product_resource = closest.product
  assign model_info_reference = product_resource.metafields.models.model_info
  assign model_size = product_resource.metafields.model.wearing_size
  assign model_info = blank

  if model_info_reference != blank
    assign model_info = model_info_reference.value
  endif

  assign model_name = blank
  assign model_height = blank
  assign model_bust = blank
  assign model_waist = blank
  assign model_hips = blank

  if model_info != blank
    assign model_name = model_info.name.value | default: model_info.name
    assign model_height = model_info.height.value | default: model_info.height
    assign model_bust = model_info.bust.value | default: model_info.bust
    assign model_waist = model_info.waist.value | default: model_info.waist
    assign model_hips = model_info.hips.value | default: model_info.hips
  endif
%}

{% if model_info != blank %}
  <div class="model-info" {{ block.shopify_attributes }}>
    {% if model_name != blank %}
      <p class="model-info__summary">
        {{ model_name | escape }} is {{ model_height | escape }} ft and wearing size {{ model_size | escape }}
      </p>
    {% endif %}

    {% if model_name != blank %}
      <p class="model-info__heading">{{ model_name | escape }}'s measurements</p>
    {% else %}
      <p class="model-info__heading">Measurements</p>
    {% endif %}

    <ul class="model-info__list">
      {% if model_bust != blank %}
        <li class="model-info__item">
          <span class="model-info__label">Bust</span>
          <span class="model-info__value">{{ model_bust | escape }}</span>
        </li>
      {% endif %}
      {% if model_waist != blank %}
        <li class="model-info__item">
          <span class="model-info__label">Waist</span>
          <span class="model-info__value">{{ model_waist | escape }}</span>
        </li>
      {% endif %}
      {% if model_hips != blank %}
        <li class="model-info__item">
          <span class="model-info__label">Hips</span>
          <span class="model-info__value">{{ model_hips | escape }}</span>
        </li>
      {% endif %}
    </ul>
  </div>
{% endif %}

{% stylesheet %}
  .model-info {
    background-color: rgb(var(--color-foreground-rgb) / 0.02);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: var(--style-border-radius-inputs);
    padding: var(--padding-md);
    display: grid;
    gap: var(--gap-xs);
  }

  .model-info__summary {
    margin: 0;
    font-size: var(--font-paragraph-small--size);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    line-height: var(--font-paragraph--line-height);
  }

  .model-info__heading {
    margin: 0;
    font-size: var(--font-paragraph-medium--size);
    font-weight: var(--font-paragraph--weight-bold);
    line-height: var(--font-paragraph--line-height);
    padding-top: var(--padding-2xs);
  }

  .model-info__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .model-info__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--gap-sm);
    align-items: baseline;
    padding-block: var(--padding-2xs);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
  }

  .model-info__label {
    font-size: var(--font-paragraph-small--size);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .model-info__value {
    font-size: var(--font-paragraph--size);
    font-weight: var(--font-weight-medium);
    text-align: right;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Model Info",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "Model Info",
      "category": "Product"
    }
  ]
}
{% endschema %}
